{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.cocapn.ai/cocapn-template.json",
  "title": "Cocapn Template Manifest",
  "description": "Manifest file for Cocapn templates (cocapn-template.json). Templates are npm-style packages that define Cocapn agent instances with personalities, skills, modules, and configuration.",
  "type": "object",
  "required": ["name", "version", "description", "author"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Template identifier (kebab-case, starting with letter)",
      "pattern": "^[a-z][a-z0-9-]*$",
      "examples": ["bare", "cloud-worker", "dmlog", "studylog"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.]+)?$",
      "examples": ["1.0.0", "2.1.3-beta.1"]
    },
    "description": {
      "type": "string",
      "description": "Short description of what this template provides",
      "minLength": 10,
      "maxLength": 200
    },
    "author": {
      "type": "string",
      "description": "Template author or organization",
      "examples": ["Cocapn", "Jane Doe <jane@example.com>"]
    },
    "license": {
      "type": "string",
      "description": "Software license (SPDX identifier)",
      "default": "MIT",
      "examples": ["MIT", "Apache-2.0", "GPL-3.0-or-later"]
    },
    "keywords": {
      "type": "array",
      "description": "Search keywords for discoverability",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "minItems": 1,
      "maxItems": 10,
      "examples": [["ttrpg", "dungeon-master", "dice"], ["education", "learning", "flashcards"]]
    },
    "homepage": {
      "type": "string",
      "description": "Template homepage URL",
      "format": "uri",
      "examples": ["https://cocapn.ai/templates/dmlog"]
    },
    "repository": {
      "type": "string",
      "description": "Source code repository URL",
      "format": "uri",
      "examples": ["https://github.com/cocapn/templates"]
    },
    "domains": {
      "type": "array",
      "description": "Domains this template is designed for",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9.-]+\\.[a-z]{2,}$"
      },
      "minItems": 1,
      "examples": [["dmlog.ai"], ["studylog.ai", "education.ai"]]
    },
    "emoji": {
      "type": "string",
      "description": "Single emoji icon for the template",
      "examples": ["🎲", "📚", "💼", "🔧"]
    },
    "features": {
      "type": "array",
      "description": "Feature flags enabled by default",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "examples": [["dice-roller", "encounter-generator"], ["spaced-repetition", "quiz-generator"]]
    },
    "modules": {
      "type": "array",
      "description": "Pre-installed module references",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "examples": [["https://github.com/cocapn/module-dice-roller"], ["https://github.com/cocapn/module-flashcards"]]
    },
    "cocapn": {
      "type": "object",
      "description": "Cocapn-specific configuration",
      "properties": {
        "minVersion": {
          "type": "string",
          "description": "Minimum Cocapn version required",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "bridge": {
          "type": "object",
          "description": "Bridge configuration",
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1024,
              "maximum": 65535,
              "default": 8787
            },
            "auth": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "brain": {
          "type": "object",
          "description": "Brain/memory configuration",
          "properties": {
            "private": {
              "type": "boolean",
              "default": true,
              "description": "Whether this template uses a private brain repo"
            },
            "encryption": {
              "type": "string",
              "enum": ["age", "none"],
              "default": "age"
            }
          }
        }
      }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "skillCartridge": {
      "type": "object",
      "description": "A skill cartridge definition",
      "properties": {
        "name": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "description": "Regex or keyword trigger for this skill"
        },
        "prompt": {
          "type": "string",
          "description": "System prompt for this skill"
        }
      }
    }
  }
}
